pkgname=logan
pkgver=4c1ebca8395723075e3108bea1a6833420485398
pkgrel=0
pkgdesc="Meituan-Dianping Logan is a lightweight, reliable, and secure mobile log system."
url="https://github.com/Meituan-Dianping/Logan"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("Apache-2.0")
depends=("zlib")
makedepends=("cmake" "make" "git")
source="https://github.com/Meituan-Dianping/Logan.git"
autounpack=false
downloadpackage=false
buildtools="cmake"
cloneflag=true
builddir="logan-master"
packagename=""

source envset.sh

prepare() {
    LOCAL_ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
    LOCAL_SOURCE_DIR="$LOCAL_ROOT_DIR/$builddir"

    if [ "$cloneflag" == "true" ]; then
        if [ -d "$LOCAL_SOURCE_DIR" ]; then
            rm -rf "$LOCAL_SOURCE_DIR"
        fi
        
        git clone $source "$LOCAL_SOURCE_DIR"
        cd "$LOCAL_SOURCE_DIR"
        git checkout $pkgver
        cd - > /dev/null
        cloneflag=false
    fi

    if [ ! -f "$LOCAL_SOURCE_DIR/Logan/Clogan/CMakeLists.txt" ]; then
        exit 1
    fi

    if [ "$ARCH" == "armeabi-v7a" ]; then
        setarm32ENV
    elif [ "$ARCH" == "arm64-v8a" ]; then
        setarm64ENV
    elif [ "$ARCH" == "x86_64" ]; then
        setx86_64ENV
    fi

    mkdir -p "$LOCAL_SOURCE_DIR/Logan/Clogan/build_${ARCH}"
}

build() {
    LOCAL_ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
    LOCAL_SOURCE_DIR="$LOCAL_ROOT_DIR/$builddir"
    cd "$LOCAL_SOURCE_DIR/Logan/Clogan/build_${ARCH}"
    cmake "$LOCAL_SOURCE_DIR/Logan/Clogan" "$@"
    
    $MAKE
}

package() {
    cd "$LYCIUM_ROOT" || exit 1
    
    mkdir -p "usr/$pkgname/$ARCH/include" "usr/$pkgname/$ARCH/lib"
    
    cp "$LYCIUM_ROOT/../thirdparty/logan/$builddir/Logan/Clogan/build_${ARCH}/libclogan.a" "usr/$pkgname/$ARCH/lib/"
    cp "$LYCIUM_ROOT/../thirdparty/logan/$builddir/Logan/Clogan"/*.h "usr/$pkgname/$ARCH/include/"
}

check() {
    return 0
}

cleanbuild() {
    LOCAL_ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
    LOCAL_SOURCE_DIR="$LOCAL_ROOT_DIR/$builddir"

    rm -rf "$LOCAL_SOURCE_DIR/Logan/Clogan"/build_*
}