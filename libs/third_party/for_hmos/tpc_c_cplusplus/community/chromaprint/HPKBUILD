pkgname=chromaprint
pkgver=1.5.1
pkgrel=0
pkgdesc="C library for generating audio fingerprints used by AcoustID"
url="https://github.com/acoustid/chromaprint"
archs=("armeabi-v7a" "arm64-v8a")
license="LGPLv2.1"
depends=("FFmpeg" "googletest")
makedepends=()
source="https://github.com/acoustid/chromaprint/archive/refs/tags/v1.5.1.tar.gz"


autounpack=true
downloadpackage=true
buildtools="cmake"

builddir=$pkgname-${pkgver}
packagename=$builddir.tar.gz

prepare() {
    mkdir -p $builddir/$ARCH-build
}

build() {
    cd $builddir
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" -DBUILD_TESTS=OFF -DBUILD_TOOLS=OFF \
        -B$ARCH-build -S./ > $buildlog 2>&1
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    $MAKE -C $ARCH-build install >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
    return $ret
}
