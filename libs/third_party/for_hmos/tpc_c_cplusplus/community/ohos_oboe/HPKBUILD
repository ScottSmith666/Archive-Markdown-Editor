pkgname=ohos_oboe
pkgver=1.10.1
pkgrel=0
pkgdesc="Oboe is a C++ library that makes it easy to build high-performance audio apps on HarmonyOS."
url="https://github.com/google/oboe"
archs=("armeabi-v7a" "arm64-v8a")
license=("Apache-2.0 license")
depends=("googletest_1.11.0")
makedepends=()

source="https://gitcode.com/OpenHarmony-ApplicationTPC/ohos_oboe.git"

autounpack=false
downloadpackage=false
buildtools="cmake"
isClone=true
builddir=${pkgname}-${pkgver}
targetArch=

source envset.sh
prepare() {
    if $isClone
    then
        git clone --recursive --depth=1 ${source} ${builddir} > $publicbuildlog 2>&1
        isClone=false
    fi

    if [ $ARCH == "armeabi-v7a" ]
    then
        setarm32ENV
        targetArch="arm"
    elif [ $ARCH == "arm64-v8a" ]
    then
        setarm64ENV
        targetArch="aarch64"
    fi

    mkdir -p $builddir/$ARCH-build
    mkdir -p $builddir/tests/$ARCH-build
}

build() {
    cd ${builddir}/${ARCH}-build
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" -S ../ -B ./ \
        -DCMAKE_SYSTEM_NAME=OpenHarmony \
        -DCMAKE_SYSTEM_PROCESSOR=${targetArch} \
        -DCMAKE_C_COMPILER=${CC} \
        -DCMAKE_CXX_COMPILER=${CXX} \
        -DCMAKE_AR=${AR} \
        -DCMAKE_LINKER=${LD} \
        -DCMAKE_RANLIB=${RANLIB} \
        -DCMAKE_OBJDUMP=${OBJDUMP} \
        -DCMAKE_OBJCOPY=${OBJCOPY} \
        -DCMAKE_STRIP=${STRIP} \
        -DOBOE_ANDROID_PLATFORM=OFF \
        -DOBOE_OHOS_PLATFORM=ON \
        -DBUILD_SHARED_LIBS=true > $buildlog 2>&1

    $MAKE -j$(nproc) >> $buildlog 2>&1
    ret=$?
    if [ $ret -ne 0 ]
    then
        return $ret
    fi
    cd $OLDPWD

    cd ${builddir}/tests/${ARCH}-build
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" -S ../ -B ./ \
        -DCMAKE_SYSTEM_NAME=OpenHarmony \
        -DCMAKE_SYSTEM_PROCESSOR=${targetArch} \
        -DCMAKE_C_COMPILER=${CC} \
        -DCMAKE_CXX_COMPILER=${CXX} \
        -DCMAKE_AR=${AR} \
        -DCMAKE_LINKER=${LD} \
        -DCMAKE_RANLIB=${RANLIB} \
        -DCMAKE_OBJDUMP=${OBJDUMP} \
        -DCMAKE_OBJCOPY=${OBJCOPY} \
        -DCMAKE_STRIP=${STRIP} \
        -DOBOE_ANDROID_PLATFORM=OFF \
        -DOBOE_OHOS_PLATFORM=ON \
        -DCMAKE_CXX_FLAGS="-Wno-unused-command-line-argument" \
        -DGOOGLETEST_ROOT="${LYCIUM_ROOT}/../community/googletest_1.11.0/googletest-release-1.11.0/googletest" \
        >> $buildlog 2>&1
    $MAKE -j$(nproc) >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd ${builddir}/${ARCH}-build
    $MAKE install >> ${buildlog} 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

check() {
    echo "The test must be on an OpenHarmony device!"
    if [ $ARCH == "armeabi-v7a" ]
    then
        unsetarm32ENV
    elif [ $ARCH == "arm64-v8a" ]
    then
        unsetarm64ENV
    fi
}

# 清理环境
cleanbuild(){
    rm -rf ${PWD}/$builddir
}
