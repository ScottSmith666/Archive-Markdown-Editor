pkgname=libsdl
pkgver=SDL2
pkgrel=2.28.5
pkgdesc="Simple DirectMedia Layer (SDL for short) is a cross-platform library designed to make it easy to write multi-media software, such as games and emulators."
url="https://www.libsdl.org/"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("zlib License")
depends=()
makedepends=()
source="https://github.com/libsdl-org/SDL/releases/download/release-${pkgrel}/${pkgver}-${pkgrel}.tar.gz"
autounpack=true
downloadpackage=true
buildtools="cmake"
builddir=$pkgver-$pkgrel
packagename=$builddir.tar.gz

prepare() {
    mkdir -p $builddir/build/$ARCH-build
}

build() {
    local LOCAL_CFLAGS="-O3 -fstack-protector-strong -fPIC"
    local LOCAL_CXXFLAGS="-O3 -fstack-protector-strong -fPIC"
    local LOCAL_LDFLAGS="-Wl,-z,relro,-z,now -Wl,--disable-new-dtags -s"

    cd "$builddir"

    sed -i 's/pthread_setcanceltype/\/\/pthread_setcanceltype/g' src/thread/pthread/SDL_systhread.c

    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DOHOS_ARCH="$ARCH" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_C_FLAGS="${LOCAL_CFLAGS}" \
        -DCMAKE_CXX_FLAGS="${LOCAL_CXXFLAGS}" \
        -DCMAKE_C_FLAGS_RELEASE="-O3 -DNDEBUG" \
        -DCMAKE_CXX_FLAGS_RELEASE="-O3 -DNDEBUG" \
        -DCMAKE_SHARED_LINKER_FLAGS="${LOCAL_LDFLAGS}" \
        -DCMAKE_EXE_LINKER_FLAGS="${LOCAL_LDFLAGS}" \
        -DCMAKE_SKIP_RPATH=TRUE \
        -DCMAKE_SKIP_INSTALL_RPATH=ON \
        -DCMAKE_POSITION_INDEPENDENT_CODE=ON \
        -DPKG_CONFIG_EXECUTABLE="" \
        -DHAVE_PTHREADS=TRUE \
        -DSDL_ALSA=OFF \
        -DSDL_TESTS=ON \
        -B"build/$ARCH-build" -S./ -L > "$PWD/build/$ARCH-build/make.log" 2>&1

    make -j4 -C "build/$ARCH-build" >> "$PWD/build/$ARCH-build/build.log" 2>&1
    local ret=$?
    cd "$OLDPWD"
    return $ret
}

package() {
    cd "$builddir"
    make -C build/$ARCH-build install >> `pwd`/build/$ARCH-build/install.log 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}