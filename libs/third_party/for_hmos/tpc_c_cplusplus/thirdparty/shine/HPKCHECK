# 加载HPKBUILD配置
source HPKBUILD > /dev/null 2>&1

# 设置日志文件路径
logfile=${LYCIUM_THIRDPARTY_ROOT}/${pkgname}/${pkgname}_${ARCH}_${OHOS_SDK_VER}_test.log

openharmonycheck() {
    res=0
    build_target_dir="${builddir}-${ARCH}-build"

    cd "$build_target_dir"
    export LD_LIBRARY_PATH=.libs:$LD_LIBRARY_PATH
    ./.libs/shineenc ./js/test/lib/encode.wav test.mp3 > ${logfile} 2>&1

    res=$?
    cd $OLDPWD

    return $res
}
