pkgname=themis
pkgver=0.15.6
pkgrel=0
pkgdesc="Themis is a cross-platform high-level cryptographic library for mobile, web, and server platforms."
url="https://github.com/cossacklabs/themis"
archs=("arm64-v8a" "armeabi-v7a" "x86_64")
license=("Apache License 2.0")
depends=("openssl-3.4.0")
makedepends=()
source="https://github.com/cossacklabs/themis/archive/refs/tags/$pkgver.tar.gz"

downloadpackage=true
autounpack=true
buildtools=cmake

builddir=$pkgname-${pkgver}
packagename=$builddir.tar.gz
patchflag=true

prepare() {
    mkdir -p ${builddir}/${ARCH}-build
    if ${patchflag}
    then
        cd ${builddir}
        # 1. 指定c++17标准, 开启std::string_view测试项
        # 2. 指定-O3编译优化选项
        # 3. 添加find_package查找openssl
        # 4. 添加cmake安装规则
        # 5. 处理armeabi-v7a平台测试用例崩溃问题
        patch -p1 < ../themis_0.15.6_oh_pkg.patch
        echo "patching success"
        patchflag=false
        cd $OLDPWD
    fi
}

build() {
    cd ${builddir}
    
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DOHOS_ARCH=${ARCH} -B${ARCH}-build -S./ -L > $buildlog 2>&1
    $MAKE -C ${ARCH}-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd ${builddir}/${ARCH}-build
    $MAKE install >> $buildlog 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/${builddir}
    return 0
}