 ##############################################################################
 
+# 加载必要的模块
+use Socket;
+use strict;
+use warnings;
+
+BEGIN {
+  # 保存原函数的引用
+  my $orig_gethostbyname = \&CORE::gethostbyname;
+
+  # 重定义全局 gethostbyname
+  *CORE::GLOBAL::gethostbyname = sub {
+    my $host = shift;
+
+    # 强制 localhost/127.0.0.1 解析为 127.0.0.1
+    if (lc($host) eq 'localhost' || $host eq '127.0.0.1') {
+      my $ip_bin = pack('C4', 127, 0, 0, 1); # 127.0.0.1 的二进制形式
+      return (
+        'localhost', # 主机名
+        '',          # 别名
+        AF_INET,     # 地址类型（IPv4）
+        4,           # 地址长度（4 字节）
+        $ip_bin      # IP 二进制数据
+      );
+    }
+
+    # 其他主机名调用原函数
+    return $orig_gethostbyname->($host);
+  };
+
+  # 重写 inet_aton 函数（确保 Socket 模块解析正常）
+  my $orig_inet_aton = \&Socket::inet_aton;
+  *Socket::inet_aton = sub {
+    my $host = shift;
+    if (lc($host) eq 'localhost' || $host eq '127.0.0.1') {
+      return pack('C4', 127, 0, 0, 1);
+    }
+    return $orig_inet_aton->($host);
+  };
+
+  # 重写 gethostbyaddr 函数（兜底，防止反向解析失败）
+  my $orig_gethostbyaddr = \&CORE::gethostbyaddr;
+  *CORE::GLOBAL::gethostbyaddr = sub {
+    my ($addr, $addrtype) = @_;
+    my $ip = inet_ntoa($addr);
+    if ($ip eq '127.0.0.1') {
+      return (
+        'localhost',
+        '',
+        AF_INET,
+        4,
+        $addr
+      );
+    }
+    return $orig_gethostbyaddr->($addr, $addrtype);
+  };
+}
+
+
