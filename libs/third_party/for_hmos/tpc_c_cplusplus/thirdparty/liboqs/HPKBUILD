pkgname=liboqs
pkgver=0.15.0
pkgrel=0
pkgdesc="Open Quantum Safe (OQS) library providing quantum-resistant cryptographic algorithms"
url="https://github.com/open-quantum-safe/liboqs"

archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("MIT")
depends=("openssl-3.4.0")
makedepends=()

source="https://github.jobcher.com/gh/https://github.com/open-quantum-safe/liboqs/archive/refs/tags/$pkgver.tar.gz"

downloadpackage=true
autounpack=true
buildtools="cmake"

builddir=$pkgname-$pkgver
packagename=$builddir.tar.gz

prepare() {
    mkdir -p $builddir/$ARCH-build
}

build() {
    cd $builddir
    
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DOHOS_ARCH=$ARCH \
        -DCMAKE_BUILD_TYPE=Release \
        -DOQS_PERMIT_UNSUPPORTED_ARCHITECTURE=ON \
        -DOQS_USE_OPENSSL=ON \
        -DOQS_ENABLE_SIG_STFL_LMS=ON \
        -DOQS_ENABLE_SIG_STFL_XMSS=ON \
        -DOQS_HAZARDOUS_EXPERIMENTAL_ENABLE_SIG_STFL_KEY_SIG_GEN=ON \
        -DOQS_ALGS_ENABLED=All \
        -DBUILD_TESTING=ON \
        -DCMAKE_C_FLAGS_RELEASE="-s" \
 	    -DCMAKE_CXX_FLAGS_RELEASE="-s" \
        -B$ARCH-build \
        -S./ > $buildlog 2>&1
    
    $MAKE -C "${ARCH}-build" VERBOSE=1 >> $buildlog 2>&1
    
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    $MAKE -C $ARCH-build install >> $buildlog 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

# 清理环境
cleanbuild(){
    rm -rf ${PWD}/$builddir
}