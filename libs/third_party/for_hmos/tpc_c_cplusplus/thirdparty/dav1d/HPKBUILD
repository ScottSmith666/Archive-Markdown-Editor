pkgname=dav1d
pkgver=1.5.2
pkgrel=0
pkgdesc="The reference implementation of the ohos dav1d (AV1 decoder) interface"
url="https://code.videolan.org/videolan/dav1d"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("BSD 2-Clause")
depends=()
makedepends=("meson")
source="https://code.videolan.org/videolan/$pkgname/-/archive/$pkgver/$pkgname-$pkgver.tar.gz"
buildtools="meson"
downloadpackage=true
autounpack=true

builddir=$pkgname-$pkgver
packagename=$builddir".tar.gz"

prepare() {
    cp $ARCH-cross-file.txt $builddir
    mkdir -p $builddir/$ARCH-build
}

build() {
    cd $builddir
    ohos_sdk_path=${OHOS_SDK//\//\\\/}
    sed -i 's/ohos_sdk/'"$ohos_sdk_path"'/g' $ARCH-cross-file.txt
    meson $ARCH-build --cross-file $ARCH-cross-file.txt --prefix=$LYCIUM_ROOT/usr/$pkgname/$ARCH  -Dtrim_dsp=false -Denable_tools=true  -Denable_asm=true  > $buildlog 2>&1
    $Ninja -v -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    $Ninja -v -C $ARCH-build install >> $buildlog 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/$builddir
}
