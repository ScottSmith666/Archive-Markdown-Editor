source HPKBUILD > /dev/null 2>&1
logfile=${LYCIUM_THIRDPARTY_ROOT}/${pkgname}/${pkgname}_${ARCH}_${OHOS_SDK_VER}_test.log

openharmonycheck() {
    res=0
    cd ${builddir}/${ARCH}-build/tests

    total_tests=0
    [ -x "./checkasm" ] && ((total_tests++))
    for test_exe in *_test; do
        [ -x "./$test_exe" ] && ((total_tests++))
    done
    test_counter=0

    if [ -x "./checkasm" ]; then
        ((test_counter++))
        ./checkasm >> ${logfile} 2>&1
        res=$?
        if [ $res -eq 0 ]; then
            printf "%-35s \033[0;32m%8s\033[0m\n" "$test_counter/$total_tests dav1d:checkasm / checkasm" "OK" >> ${logfile}
        else
            printf "%-35s \033[0;31m%8s\033[0m\n" "$test_counter/$total_tests dav1d:checkasm / checkasm" "FAILED" >> ${logfile}
            mkdir -p $LYCIUM_FAULT_PATH/$pkgname
            cp Testing/Temporary/LastTest.log $LYCIUM_FAULT_PATH/$pkgname 2>&1
        fi
    fi

    header_failed=0
    header_test_exes=(*_test)
    for test_exe in "${header_test_exes[@]}"; do
        if [ -x "./$test_exe" ]; then
            ((test_counter++))
            ./"$test_exe" >> ${logfile} 2>&1
            test_res=$?
            if [ $test_res -eq 0 ]; then
                printf "%-35s \033[0;32m%8s\033[0m\n" "$test_counter/$total_tests dav1d:headers / $test_exe" "OK" >> ${logfile}
            else
                printf "%-35s \033[0;31m%8s\033[0m\n" "$test_counter/$total_tests dav1d:headers / $test_exe" "FAILED" >> ${logfile}
                header_failed=1
                mkdir -p $LYCIUM_FAULT_PATH/$pkgname
                cp Testing/Temporary/LastTest.log $LYCIUM_FAULT_PATH/$pkgname 2>&1
            fi
        fi
    done

    if [ $header_failed -ne 0 ]; then
        res=$header_failed
    fi

    cd $OLDPWD
    return $res
}
