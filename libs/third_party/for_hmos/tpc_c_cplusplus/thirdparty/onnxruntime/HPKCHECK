source HPKBUILD > /dev/null 2>&1

logfile="${LYCIUM_THIRDPARTY_ROOT}/${pkgname}/${pkgname}_${ARCH}_${OHOS_SDK_VER}_test.log"

openharmonycheck() {
    echo "Running test..."

    cd $builddir/build/OHOS/${ARCH}/Release

    ## onnxruntime在编译时启用了BF16扩展
    ## 实际运行时, onnxruntime根据cpuinfo判断是否启用BF16优化
    ## 但cpuinfo当前在不支持BF扩展的cpu上存在判断异常
    ## https://github.com/microsoft/onnxruntime/issues/27017
    ## 先执行一次失败测试可以规避掉这个问题
    ./onnxruntime_test_all --gtest_filter='MathOpTest.MatMulFloatType_FastMath' > /dev/null

    ./onnxruntime_test_all >> "${logfile}" 2>&1
    ret=$?

    cd "$OLDPWD"
    return $ret
}