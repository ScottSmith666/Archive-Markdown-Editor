pkgname=redsocks
pkgver=0.5
pkgrel=0
pkgdesc="transparent TCP-to-proxy redirector"
url="https://github.com/darkk/redsocks"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("Apache-2.0 license")
depends=("curl" "openssl-3.4.0" "libevent")
makedepends=()
source="https://github.com/darkk/redsocks/archive/refs/tags/release-${pkgver}.tar.gz"

downloadpackage=true
autounpack=true
buildtools=make
patchflag=true

builddir=$pkgname-release-${pkgver}
packagename=$pkgname-release-${pkgver}.tar.gz
source envset.sh

prepare() {
    # 由于平台不同，日志格式不同，导致编译失败，故需要打patch统一日志格式
    if [ "$patchflag" == true ]
    then
        cd $builddir
        patch -p0 < ../redsocks.patch
        cd $OLDPWD
        patchflag=false
    fi

    cp -rf $builddir $builddir-$ARCH-build

    if [ $ARCH == "armeabi-v7a" ]
    then
        setarm32ENV
        host=arm-linux
    elif [ $ARCH == "arm64-v8a" ]
    then
        setarm64ENV
        host=aarch64-linux
    elif [ $ARCH == "x86_64" ]
    then
        setx86_64ENV
        host=x86_64-linux    
    else
        echo "${ARCH} not support"
        return -1
    fi
}

build() {
    cd $builddir-$ARCH-build
    
    $MAKE CC=$CC \
    CFLAGS="-mfloat-abi=hard -mfpu=neon \
        -D__MUSL__=1 \
        -static -O0 \
        -I${LYCIUM_ROOT}/usr/openssl/$ARCH/include/ \
        -I${LYCIUM_ROOT}/usr/libevent/$ARCH/include/ \
        -s" \
    LDFLAGS="--sysroot=${OHOS_SDK}/native/sysroot \
        -static \
        -B${OHOS_SDK}/native/sysroot/usr/lib/ \
        -L${LYCIUM_ROOT}/usr/openssl/$ARCH/lib/ \
        -L${LYCIUM_ROOT}/usr/libevent/$ARCH/lib/ \
        -levent -lssl -lcrypto -ldl -lc -s" > $buildlog 2>&1
    
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir-$ARCH-build
    mkdir -p ${LYCIUM_ROOT}/usr/${pkgname}/${ARCH}/bin/
    cp -r redsocks $LYCIUM_ROOT/usr/$pkgname/$ARCH/bin/
    cd $OLDPWD

    if [ $ARCH == "armeabi-v7a" ]
    then
        unsetarm32ENV
    elif [ $ARCH == "arm64-v8a" ]
    then
        unsetarm64ENV
    elif [ $ARCH == "x86_64" ]
    then
        unsetx86_64ENV    
    else
        echo package no support $ARCH !!
        return -1
    fi
    unset host
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/${builddir} ${PWD}/${builddir}-armeabi-v7a-build ${PWD}/${builddir}-arm64-v8a-build ${PWD}/${builddir}-x86_64-build #${PWD}/$packagename
}
