pkgname=libuvc
pkgver=0.0.7
pkgrel=0
pkgdesc="A cross-platform library for USB video devices"
url="https://github.com/libuvc/libuvc"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("BSD")
depends=("libusb" "opencv")
makedepends=()

source="https://github.com/libuvc/libuvc/archive/refs/tags/v$pkgver.tar.gz"

autounpack=true
downloadpackage=true
buildtools="cmake"
patchflag=true
builddir="$pkgname-$pkgver"
packagename="v$pkgver.tar.gz"

prepare() {
    if $patchflag
    then
        # 将测试程序 uvc_test 从 “纯 C 编译” 改为 “用 C++ 编译器编译”
        patch -p1 < libuvc.patch > $publicbuildlog 2>&1
        patchflag=false
    fi
    mkdir -p "$builddir/$ARCH-build"
}

build() {
    cd "$builddir"

    PKG_CONFIG_LIBDIR="${pkgconfigpath}" ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DBUILD_SHARED_LIBS=ON -DBUILD_TEST=ON -B"$ARCH-build" -S./ > $buildlog 2>&1

    $MAKE -C ${ARCH}-build >> $buildlog 2>&1
    local ret=$?

    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    $MAKE -C ${ARCH}-build install >> $buildlog 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/$builddir
}