pkgname=zlib
pkgver=1.3.2
pkgrel=0
pkgdesc="zlib is designed to be a free, general-purpose, legally unencumbered -- that is, not covered by any patents -- lossless data-compression library for use on virtually any computer hardware and operating system"
url="https://zlib.net/"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=()
depends=()
makedepends=()
source="https://$pkgname.net/fossils/$pkgname-$pkgver.tar.gz"

autounpack=true
downloadpackage=true
builddir=$pkgname-${pkgver}
packagename=$builddir.tar.gz
buildtools="cmake"

prepare() {
    mkdir -p $builddir/$ARCH-build
}

build() {
    local LOCAL_LDFLAGS="-Wl,-z,relro,-z,now -Wl,--disable-new-dtags -s"

    cd "$builddir"

    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DCMAKE_SHARED_LINKER_FLAGS="${LOCAL_LDFLAGS}" \
        -DCMAKE_EXE_LINKER_FLAGS="${LOCAL_LDFLAGS}" \
        -DCMAKE_C_FLAGS_RELEASE="-O3 -fstack-protector-strong -fPIC -DNDEBUG" \
        -DCMAKE_CXX_FLAGS_RELEASE="-O3 -fstack-protector-strong -fPIC -DNDEBUG" \
        -B"$ARCH-build" -S./ > "$buildlog" 2>&1

    $MAKE VERBOSE=1 -C "$ARCH-build" >> "$buildlog" 2>&1
    local ret=$?
    cd "$OLDPWD"
    return $ret
}

package() {
    cd $builddir
    $MAKE -C $ARCH-build install VERBOSE=1 >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

check() {
    if [ $ARCH == "armeabi-v7a" ]
    then
        cp ${OHOS_SDK}/native/llvm/lib/arm-linux-ohos/libc++_shared.so $LYCIUM_ROOT/usr/$pkgname/$ARCH/lib/
    elif [ $ARCH == "arm64-v8a" ]
    then
        cp ${OHOS_SDK}/native/llvm/lib/aarch64-linux-ohos/libc++_shared.so $LYCIUM_ROOT/usr/$pkgname/$ARCH/lib/
    elif [ $ARCH == "x86_64" ]
    then
        cp ${OHOS_SDK}/native/llvm/lib/x86_64-linux-ohos/libc++_shared.so $LYCIUM_ROOT/usr/$pkgname/$ARCH/lib/
    else
        echo "${ARCH} not support"
        return -1.
    fi
    echo "The test must be on an OpenHarmony device!"
}

# 清理环境
cleanbuild(){
     rm -rf ${PWD}/$builddir
}




