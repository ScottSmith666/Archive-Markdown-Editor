pkgname=jemalloc
pkgver=5.3.0
pkgrel=0
pkgdesc="通用内存分配器"
url="https://github.com/jemalloc/jemalloc"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("BSD-2-Clause")
depends=()
makedepends=("make" "autoconf")

buildtools="configure"
downloadpackage=true
autounpack=true
packagename=$pkgname-$pkgver.tar.gz
builddir=$pkgname-$pkgver

source="https://github.com/$pkgname/$pkgname/archive/refs/tags/${pkgver}.tar.gz"

source envset.sh
host=
patchflag=true

prepare() {
    mkdir -p $builddir/$ARCH-build
    cd $builddir

    if ${patchflag}; then
        # 临时规避单元测试signal 11问题, 后续会持续跟进处理
        patch -p1 < ../jemalloc_5.3.0_oh_pkg.patch
        patchflag=false
    fi
    
    case "$ARCH" in
      armeabi-v7a)
        setarm32ENV
        host=arm-linux
        ;;
      arm64-v8a)
        setarm64ENV
        host=aarch64-linux
        ;;
      x86_64) 
        setx86_64ENV
        host=x86_64-linux
        ;;
    esac
    autoconf >> $buildlog 2>&1
    cd $OLDPWD
}

build() {
    cd $builddir/$ARCH-build
    PKG_CONFIG_LIBDIR="${pkgconfigpath}" ../configure "$@" \
      --host=$host --enable-shared --enable-static \
      --with-jemalloc-prefix=je_ >> $buildlog 2>&1

    $MAKE >> $buildlog 2>&1
    ret=$?
    if [ $ret -eq 0 ]; then
        $MAKE tests >> $buildlog 2>&1
        ret=$?
    fi
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir/$ARCH-build
    $MAKE install >> $buildlog 2>&1
    cd $OLDPWD
}

check() {
    unset host
    case "$ARCH" in
      armeabi-v7a) unsetarm32ENV ;;
      arm64-v8a)   unsetarm64ENV ;;
      x86_64)      unsetx86_64ENV ;;
    esac
}

cleanbuild() {
    rm -rf "${PWD}/${builddir}"
}

