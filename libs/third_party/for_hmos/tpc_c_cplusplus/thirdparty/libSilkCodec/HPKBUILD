pkgname=libSilkCodec
pkgver=bc8e724213fd66d68cb8e272cc618da698cd1990
pkgrel=0
pkgdesc="Cross-platform silk codec wrap library depends on ploverlake/silk."
url="https://github.com/LagrangeDev/libSilkCodec"
#silk不支持32位
archs=("arm64-v8a" "x86_64")
license=("MIT License")
depends=()
makedepends=()
source="https://github.com/LagrangeDev/libSilkCodec.git"

downloadpackage=false
autounpack=false
buildtools="cmake"
clonesrcflag=true

builddir=${pkgname}-${pkgver}

prepare() {
    if ${clonesrcflag}
    then
        git clone ${source} ${builddir} || return -1
        cd ${builddir}
        git reset --hard ${pkgver} || return -1
        git submodule update --init --recursive || return -1
        patch -p1 < ../libSilkCodec_oh_test.patch || return -1
        cd ${OLDPWD}
        clonesrcflag=false
    fi
    mkdir -p ${builddir}/${ARCH}-build
    return 0
}

build() {
    cd ${builddir}
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" -DOHOS_ARCH=$ARCH -B$ARCH-build -S./ -L
    make -j4 VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    if [ $ret -ne 0 ]
    then
        return $ret
    fi

    # 编译测试用例
    SILK_SDK_DIR="${builddir}/silk/src/SILK_SDK_SRC_ARM_v1.0.9"
    cd ${SILK_SDK_DIR}

    find . -name "*_arm.S" -type f -delete
    find . -name "*_arm.c" -type f -delete
    cp Makefile Makefile.bak
    if [ "$ARCH" == "arm64-v8a" ]; then
        export CC="${OHOS_SDK}/native/llvm/bin/clang -target aarch64-linux-ohos --sysroot=${OHOS_SDK}/native/sysroot -mlittle-endian"
        export CXX="${OHOS_SDK}/native/llvm/bin/clang++ -target aarch64-linux-ohos --sysroot=${OHOS_SDK}/native/sysroot -mlittle-endian"
    else
        export CC="${OHOS_SDK}/native/llvm/bin/clang -target x86_64-linux-ohos --sysroot=${OHOS_SDK}/native/sysroot"
        export CXX="${OHOS_SDK}/native/llvm/bin/clang++ -target x86_64-linux-ohos --sysroot=${OHOS_SDK}/native/sysroot"
    fi

    export AR="${OHOS_SDK}/native/llvm/bin/llvm-ar"
    export RANLIB="${OHOS_SDK}/native/llvm/bin/llvm-ranlib"
    export ADDED_CFLAGS="-Wno-constant-conversion -Wno-shift-negative-value -Wno-unused-command-line-argument"

    sed -i 's|^CC *=.*|CC = '"${CC}"'|' Makefile
    sed -i 's|^CXX *=.*|CXX = '"${CXX}"'|' Makefile
    sed -i 's|^AR *=.*|AR = '"${AR}"'|' Makefile
    sed -i 's|^RANLIB *=.*|RANLIB = '"${RANLIB}"'|' Makefile
    sed -i 's|^ADDED_DEFINES *=.*|ADDED_DEFINES = NO_ASM|' Makefile
    sed -i 's|^ADDED_CFLAGS *=.*|ADDED_CFLAGS = '"${ADDED_CFLAGS}"'|' Makefile

    if ! grep -q "\$(ADDED_CFLAGS)" Makefile; then
        sed -i '/^CFLAGS +=/ s/$/ $(ADDED_CFLAGS) $(ADDED_DEFINES)/' Makefile
        sed -i '/^CFLAGS =/ s/$/ $(ADDED_CFLAGS) $(ADDED_DEFINES)/' Makefile
    fi

    make clean >> $buildlog 2>&1
    make lib VERBOSE=1 >> $buildlog 2>&1

    if [ $? -ne 0 ]; then
        tail -100 $buildlog
        mv Makefile.bak Makefile
        cd $OLDPWD
        return 1
    fi

    if [ ! -f "libSKP_SILK_SDK.a" ]; then
        mv Makefile.bak Makefile
        cd $OLDPWD
        return 1
    fi

    make encoder decoder signalcompare VERBOSE=1 >> $buildlog 2>&1
    chmod +x encoder decoder signalcompare

    local target_dir="${OLDPWD}/${builddir}/${ARCH}-build/"
    mkdir -p "${target_dir}"
    cp -rf encoder decoder signalcompare test_vectors "${target_dir}/" >> $buildlog 2>&1
    mv Makefile.bak Makefile
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    mkdir -p ${LYCIUM_ROOT}/usr/$pkgname/$ARCH/include
    mkdir -p ${LYCIUM_ROOT}/usr/$pkgname/$ARCH/lib
    cp ${ARCH}-build/${pkgname}_static.a ${LYCIUM_ROOT}/usr/$pkgname/$ARCH/lib
    cp src/include/codec.h ${LYCIUM_ROOT}/usr/$pkgname/$ARCH/include
    ret=$?
    cd $OLDPWD
    return $ret
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/${builddir}
    return 0
}