pkgname=spdlog
pkgver=v1.16.0
pkgrel=0
pkgdesc="Spdlog is a high-performance C++log library mainly used to record runtime information (such as debugging information, error logs, etc.) in C++programs"
url="https://github.com/gabime/spdlog"
archs=("armeabi-v7a" "arm64-v8a"  "x86_64")
license=("MIT")
depends=("fmt")
makedepends=()

source="https://github.com/gabime/$pkgname/archive/refs/tags/$pkgver.zip"
downloadpackage=true
autounpack=true
buildtools="cmake"

builddir=${pkgname}-${pkgver:1}
packagename=$builddir.zip
rootDir=$PWD

prepare() {
    # 复制源码，为每个架构创建一个独立的构建目录
    cp -arf $builddir $builddir-$ARCH-build
}

build() {
    cd $builddir-$ARCH-build
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
    -DSPDLOG_BUILD_TESTS=OFF \
    -DSPDLOG_FMT_EXTERNAL_HO=ON \
    -DCMAKE_BUILD_TYPE=Release \
    -DOHOS_STL=c++_static \
    -DOHOS_ARCH=$ARCH \
    -B$ARCH-build -S./ > $buildlog 2>&1
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $rootDir
    return $ret
}

package() {
    cd $builddir-$ARCH-build
    $MAKE -C $ARCH-build install >> $buildlog 2>&1
    cd $rootDir
}

check() {
  echo "The test must be on an OpenHarmony device!"
}

# 清理环境
cleanbuild() {
    rm -rf ${PWD}/$builddir 
    rm -rf ${PWD}/$builddir-arm64-v8a-build
    rm -rf ${PWD}/$builddir-armeabi-v7a-build
    rm -rf ${PWD}/$builddir-x86_64-build
}
