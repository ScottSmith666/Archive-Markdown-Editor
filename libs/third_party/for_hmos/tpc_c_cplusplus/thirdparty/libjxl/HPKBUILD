pkgname=libjxl
pkgver=v0.11.1
pkgrel=0
pkgdesc="JPEG XL image format reference implementation"
url="https://github.com/libjxl/libjxl"
archs=("armeabi-v7a" "arm64-v8a" "x86_64") 
license=("BSD-3-Clause")
depends=("libpng" "libjpeg-turbo" "libwebp")
makedepends=()
source="https://github.com/libjxl/libjxl.git"
downloadpackage=false
autounpack=false
cloneflag=true
builddir=$pkgname-${pkgver:1}

prepare() {
     if $cloneflag
     then		
        git clone -b $pkgver --depth=1 $source $builddir >> $buildlog 2>&1
        if [ $? -ne 0 ]; then
            return -1
        fi
        
        cd $builddir
        sed -i 's|https://skia.googlesource.com/skcms|https://github.com/google/skcms.git|g' .gitmodules
        git submodule update --init --recursive --depth=1 >> $buildlog 2>&1
		if [ $? -ne 0 ]; then
            return -1
        fi
		
        cloneflag=false
        cd $OLDPWD
    fi
}

build() {
    cd $builddir
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_C_FLAGS_RELEASE="-O3 -DNDEBUG -s" \
        -DCMAKE_CXX_FLAGS_RELEASE="-O3 -DNDEBUG -s" \
        -DCMAKE_C_FLAGS_RELEASE="-s" \
        -DCMAKE_CXX_FLAGS_RELEASE="-s" \
        -DCMAKE_CROSSCOMPILING_EMULATOR=/usr/bin/true \
        -DJPEGXL_TEST_DATA_PATH="./testdata" \
        -B$ARCH-build -S./ >> $buildlog 2>&1
	
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    make -C "$ARCH-build" install >> "$ARCH-build/install.log" 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/${builddir}
}