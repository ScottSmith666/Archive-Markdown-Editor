source HPKBUILD > /dev/null 2>&1
logfile=${LYCIUM_THIRDPARTY_ROOT}/${pkgname}/${pkgname}_${ARCH}_${OHOS_SDK_VER}_test.log

libsentences_test() {
    echo "开始 libsentences 功能测试..."
    echo "当前目录: $(pwd)"
    
    # 检查必要的可执行文件
    if [ ! -f "./sbd_util" ] || [ ! -f "./sentence_splitter" ]; then
        echo "错误: 缺少必要的可执行文件"
        return 1
    fi
    
    # 创建训练数据文件
    echo "创建训练数据文件 train.txt（包含各种标点符号的句子）..."
    
    # 训练数据：
    cat > train.txt << 'EOF'
    这是一个简单的句子，以句号结束。
    这是一个问句吗？
    这是一个感叹句！
    "这是一个带引号的句子。"
    这是一个带冒号的句子：后面跟内容。
    括号(里面的内容)也可以出现在句子中。
    缩写如Dr.、Mr.、etc.都是常见的。
    价格是$19.99，包含税。
    会议在下午3:30开始。
    他说："你好！"然后笑了。
    她喊道："小心！"然后跑开了。
    王医生说："大家好！"然后他继续说。
    老板命令："立即执行！"然后离开了。
    客户说："太贵了！"然后开始讨价还价。
    He said: "Hello!" and then laughed.
    She shouted: "Be careful!" and then ran away.
    Dr. Smith said: "Hello everyone!" and then continued.
    This is a quoted sentence: "This is an example."
    Quote in the middle: "This is an example." and then continue.
    The customer said: "Too expensive!" and then started bargaining.
    我会在10:45到达。
    他在2:15离开了。
    她在4:20打了电话。
    我们在11:00见面。
    他们在5:00结束。
    概率是0.75。
    百分比是42.7%。
EOF
    
    echo "训练数据创建完成，总行数（句子数）: $(wc -l < train.txt)"
    
    # 创建测试数据文件 - 多语言复合句
    echo "创建测试数据文件 test.txt（多语言复合句）..."
    cat > test.txt << 'EOF'
    这是一个句子一。这是一个句子二。这是一个句子三！
    这是一个问句吗？是的，这是！还有另一个问句吗？
    王医生说："大家好！"然后他继续说："你们好吗？"
    会议在上午10点。请准时。不要迟到！
    我买了苹果、橙子和香蕉。它们花了¥50。这是一个好交易！
    This is sentence one. This is sentence two. And this is sentence three!
    Is this a question? Yes, it is! What about another question?
    Dr. Smith said: "Hello everyone!" Then he continued: "How are you?"
    The meeting is at 10:00 a.m. Please be on time. Don't be late!
    I bought apples, oranges, and bananas. They cost $5.99. It was a good deal!
    这是一个测试。libsentences能正确分割句子吗？让我们看看！
    "你好，OpenHarmony！"开发者说道。多么令人兴奋！
    王博士解释说："算法运行良好。"我们应该多测试一下。
    今天气温25.5°C。这是编程的完美天气！
    これはテストです。libsentencesは文を正しく分割できますか？確認してみましょう！
    「こんにちは、OpenHarmony！」と開発者が言いました。とてもエキサイティングです！
    リー博士は説明しました：「アルゴリズムはうまく機能しています。」もっとテストするべきです。
    今日の気温は25.5°Cです。コーディングには完璧な天気です！
    C'est la première phrase. C'est la deuxième phrase. C'est la troisième phrase !
    Quel temps fait-il aujourd'hui ? Il fait beau ! Et demain ?
    Le docteur Dupont a dit : "Prenez vos médicaments." Puis il a dit : "Buvez beaucoup d'eau." Enfin, il a dit : "Reposez-vous bien."
    La réunion est à 15h. Soyez à l'heure. Ne soyez pas en retard !
    J'ai acheté des pommes, des oranges et des bananes. Cela coûte 5 euros. C'est une bonne affaire !
    यह पहला वाक्य है। यह दूसरा वाक्य है। यह तीसरा वाक्य है!
    आज मौसम कैसा है? अच्छा है! और कल?
    डॉक्टर शर्मा ने कहा: "दवा लें।" फिर उन्होंने कहा: "बहुत सारा पानी पिएं।" अंत में उन्होंने कहा: "अच्छी तरह आराम करें।"
    बैठक दोपहर 3 बजे है। समय का पालन करें। देर मत करो!
    मैंने सेब, संतरे और केले खरीदे। कीमत 100 रुपये है। यह एक अच्छा सौदा है!
    هذه هي الجملة الأولى. هذه هي الجملة الثانية. هذه هي الجملة الثالثة!
    كيف هو الطقس اليوم؟ جميل! وماذا عن الغد؟
    قال الدكتور أحمد: "خذ الدواء." ثم قال: "اشرب الكثير من الماء." وأخيراً قال: "ارتح جيداً."
    الاجتماع في الساعة الثالثة بعد الظهر. كن في الوقت المحدد. لا تتأخر!
    اشتريت تفاحاً وبرتقالاً وموزاً. السعر 20 جنيهاً. إنها صفقة جيدة!
EOF
    
    echo "测试数据创建完成，总行数: $(wc -l < test.txt)"
    echo "测试数据内容:"
    # 使用带行号的显示
    line_num=1
    while IFS= read -r line; do
        echo "  $line_num: $line"
        ((line_num++))
        if [ $line_num -gt 5 ]; then
            echo "  ..."
            break
        fi
    done < test.txt
    
    # 训练模型
    echo "开始训练模型 (sbd_util)..."
    
    ./sbd_util train.txt model.txt
    local train_result=$?
    
    if [ $train_result -ne 0 ]; then
        echo "模型训练失败，返回码: $train_result"
        return 1
    fi
    
    if [ ! -f "model.txt" ]; then
        echo "错误: 模型文件未创建"
        return 1
    fi
    
    echo "模型训练完成，文件大小: $(wc -c < model.txt) 字节"
    
    # 测试句子分割 - 直接输出到日志
    echo "开始句子分割测试 (sentence_splitter)..."
    echo "测试结果:"
    
    # 运行分割器，直接输出结果
    ./sentence_splitter model.txt test.txt
    local split_result=$?
    
    if [ $split_result -ne 0 ]; then
        echo "句子分割失败，返回码: $split_result"
        return 1
    fi
    
    # 分析测试结果
    echo "测试完成"
    
    # 清理临时文件
    rm -f train.txt test.txt model.txt
    
    if [ $split_result -eq 0 ]; then
        echo "✓ libsentences 测试通过"
        return 0
    else
        return 1
    fi
}

openharmonycheck() {
    res=0
    cd ${builddir}/${ARCH}-build/
    echo "测试目录: ${builddir}/${ARCH}-build/"
    
    # 执行libsentences测试，只输出到日志文件
    libsentences_test > ${logfile} 2>&1
    res=$?
    
    if [ $res -ne 0 ]
    then
        mkdir -p ${LYCIUM_FAULT_PATH}/${pkgname}
        cp ${logfile} ${LYCIUM_FAULT_PATH}/${pkgname}/ 2>/dev/null || true
        echo "测试失败，日志已保存到故障目录"
    fi
    
    cd $OLDPWD
    return $res
}