source HPKBUILD > /dev/null 2>&1
logfile=${LYCIUM_THIRDPARTY_ROOT}/${pkgname}/${pkgname}_${ARCH}_${OHOS_SDK_VER}_test.log

openharmonycheck() {
    res=0

    local build_dir="$builddir-$ARCH-build"

    cd "${build_dir}/build/test" || {
        echo "Error: Cannot enter build directory ${build_dir}/build/test" >> ${logfile} 2>&1
        return 1
    }

    local old_ld_path="$LD_LIBRARY_PATH"
    local old_path="$PATH"

    export LD_LIBRARY_PATH="${LYCIUM_ROOT}/usr/libpng/${ARCH}/lib:${LYCIUM_ROOT}/usr/apngasm/${ARCH}/lib:${LYCIUM_ROOT}/usr/zlib/${ARCH}/lib:${old_ld_path}"
    export PATH=".:${PATH}"

    ctest >> ${logfile} 2>&1
    res=$?

    export LD_LIBRARY_PATH="$old_ld_path"
    export PATH="$old_path"

    cd $OLDPWD

	if [ $res -ne 0 ]; then
        mkdir -p "${LYCIUM_FAULT_PATH}/${pkgname}"
        cp "$logfile" "${LYCIUM_FAULT_PATH}/${pkgname}/" 2>/dev/null || true
    fi

    return $res
}
