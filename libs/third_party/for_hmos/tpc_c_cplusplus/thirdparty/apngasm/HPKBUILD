pkgname=apngasm
pkgver=3.1.10
pkgrel=1
pkgdesc="The next generation of apngasm, the APNG Assembler"
url="https://github.com/apngasm/apngasm/tree/3.1.10"
archs=("arm64-v8a" "armeabi-v7a" "x86_64")
license=(zlib license)
depends=("libpng" "zlib" "boost")
makedepends=()
source="https://codeload.github.com/apngasm/apngasm/zip/refs/tags/3.1.10"

autounpack=true
downloadpackage=true
buildtools="cmake"

builddir=${pkgname}-${pkgver}
packagename=$builddir.zip

prepare() {
    echo "Preparing build for $ARCH..."

    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local THIRDPARTY_ROOT="$(dirname "$SCRIPT_DIR")"

    cd "$THIRDPARTY_ROOT/apngasm" || {
        echo "Error: Cannot change to apngasm directory"
        return 1
    }

    echo "Current directory: $(pwd)"

    if [ ! -d "$builddir" ]; then
        echo "Error: Source directory '$builddir' not found"
        return 1
    fi

    local build_dir="$builddir-$ARCH-build"
    echo "Creating build directory: $build_dir"
    rm -rf "$build_dir"
    cp -rf "$builddir" "$build_dir"

    echo "Preparation completed for $ARCH"
}

build() {
    echo "Building for $ARCH..."

    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local THIRDPARTY_ROOT="$(dirname "$SCRIPT_DIR")"

    cd "$THIRDPARTY_ROOT/apngasm/$builddir-$ARCH-build" || {
        echo "Error: Cannot change to build directory"
        return 1
    }

    local LYCIUM_ROOT="$(dirname "$THIRDPARTY_ROOT")/lycium"
    local LIBPNG_DIR="$LYCIUM_ROOT/usr/libpng/$ARCH"
    local ZLIB_DIR="$LYCIUM_ROOT/usr/zlib/$ARCH"
    local BOOST_DIR="$LYCIUM_ROOT/usr/boost/$ARCH"

    if [ ! -f "$LIBPNG_DIR/lib/libpng.so" ]; then
        echo "Error: libpng not found at $LIBPNG_DIR/lib/libpng.so"
        return 1
    fi
    if [ ! -d "$LIBPNG_DIR/include" ]; then
        echo "Error: libpng headers not found at $LIBPNG_DIR/include"
        return 1
    fi
    if [ ! -f "$ZLIB_DIR/lib/libz.so" ]; then
        echo "Error: zlib not found at $ZLIB_DIR/lib/libz.so"
        return 1
    fi
    if [ ! -d "$ZLIB_DIR/include" ]; then
        echo "Error: zlib headers not found at $ZLIB_DIR/include"
        return 1
    fi
    if [ ! -d "$BOOST_DIR/include" ]; then
        echo "Error: boost include directory not found at $BOOST_DIR/include"
        return 1
    fi

    echo "Using libpng from: $LIBPNG_DIR"
    echo "Using zlib from: $ZLIB_DIR"
    echo "Using boost from: $BOOST_DIR"

    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_SKIP_RPATH=ON \
        -DCMAKE_SKIP_INSTALL_RPATH=ON \
        -DCMAKE_SHARED_LINKER_FLAGS="-s" \
        -DCMAKE_EXE_LINKER_FLAGS="-s" \
        -DCMAKE_TOOLCHAIN_FILE=${OHOS_SDK}/native/build/cmake/ohos.toolchain.cmake \
        -DCMAKE_INSTALL_PREFIX=${LYCIUM_ROOT}/usr/${pkgname}/${ARCH}/ \
        -DOHOS_ARCH=$ARCH \
        -DPNG_PNG_INCLUDE_DIR="${LIBPNG_DIR}/include" \
        -DPNG_LIBRARY="${LIBPNG_DIR}/lib/libpng.so" \
        -DZLIB_INCLUDE_DIR="${ZLIB_DIR}/include" \
        -DZLIB_LIBRARY="${ZLIB_DIR}/lib/libz.so" \
        -DBoost_INCLUDE_DIR="${BOOST_DIR}/include" \
        -DBOOST_ROOT="${BOOST_DIR}" \
        -DBOOST_INCLUDEDIR="${BOOST_DIR}/include" \
        -DBOOST_LIBRARYDIR="${BOOST_DIR}/lib" \
        -DBoost_USE_STATIC_LIBS=OFF \
        -DBoost_NO_SYSTEM_PATHS=ON \
        -DCMAKE_CXX_FLAGS="-I${LIBPNG_DIR}/include -I${ZLIB_DIR}/include -I${BOOST_DIR}/include" \
        -DCMAKE_C_FLAGS="-I${LIBPNG_DIR}/include -I${ZLIB_DIR}/include -I${BOOST_DIR}/include" \
        -DCMAKE_PREFIX_PATH="${LIBPNG_DIR};${ZLIB_DIR};${BOOST_DIR}" \
        -DCMAKE_FIND_ROOT_PATH="${LIBPNG_DIR};${ZLIB_DIR};${BOOST_DIR}" \
        -DPNG_INCLUDE_DIR="${LIBPNG_DIR}/include" \
        -B build -S . > $buildlog 2>&1

    if [ $? -ne 0 ]; then
        echo "CMake configuration failed. Check $buildlog for details."
        return 1
    fi

    ${MAKE} VERBOSE=1 -C build apngasm-dynamic >>  $buildlog 2>&1
    ${MAKE} VERBOSE=1 -C build apngasm-static >>  $buildlog 2>&1
    ${MAKE} VERBOSE=1 -C build >>  $buildlog 2>&1

    ${MAKE} VERBOSE=1 -C build  apngasm-cpp-test >>  $buildlog 2>&1
    ret=$?

    if [ $ret -ne 0 ]; then
        echo "Build failed. Check $buildlog for details."
    fi

    cd $OLDPWD
    return $ret
}

package() {
    echo "Packaging for $ARCH..."

    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local THIRDPARTY_ROOT="$(dirname "$SCRIPT_DIR")"

    cd "$THIRDPARTY_ROOT/apngasm/$builddir-$ARCH-build" || {
        echo "Error: Cannot change to build directory"
        return 1
    }

    ${MAKE} -C build install >> $buildlog 2>&1
    ret=$?

    if [ $ret -ne 0 ]; then
        echo "Installation failed. Check $buildlog for details."
    fi

    cd $OLDPWD
    return $ret
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild(){
    rm -rf ${PWD}/$builddir \
           $builddir-armeabi-v7a-build \
           $builddir-arm64-v8a-build \
           $builddir-x86_64-build
}