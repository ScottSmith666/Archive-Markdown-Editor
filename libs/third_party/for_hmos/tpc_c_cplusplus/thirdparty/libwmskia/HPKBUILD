pkgname=skia
pkgver="canvaskit/0.37.0"
pkgrel=0
pkgdesc=""
url="https://gitcode.com/gh_mirrors/skia1/skia"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("BSD 3-Clause License")
depends=()
makedepends=("python3" "git")
# 指定源码地址（GitCode raw，用户要求；不用 GitHub）
source="https://raw.gitcode.com/gh_mirrors/skia1/skia/archive/refs/heads/canvaskit/0.37.0.tar.gz"
# 与 source 同一 gh_mirrors/skia1/skia 仓库；raw 直链自动化下载常非 gzip，prepare 用 git clone 拉等价分支
gitcode_repo="https://gitcode.com/gh_mirrors/skia1/skia.git"
autounpack=false
downloadpackage=false
builddir=${pkgname}-${pkgver//\//-}
packagename=
cloneflag=true
depsyncflag=true
prepare() {
    if [ "$cloneflag" == true ]; then
        git clone -b "$pkgver" --depth=1 "$gitcode_repo" "$builddir" > $publicbuildlog 2>&1
        if [ $? -ne 0 ]; then
            echo "$pkgname: git clone $gitcode_repo -b $pkgver failed (source ref: $source)"
            rm -rf "$builddir"
            return -1
        fi
        cloneflag=false
    fi
    # 拉取 Skia 第三方依赖（与 zlib/tensorflow-lite 等流程一致）
    if [ "$depsyncflag" == true ]; then
        cd $builddir
        python3 tools/git-sync-deps > $publicbuildlog 2>&1
        respy=$?
        cd $OLDPWD
        if [ $respy -ne 0 ]; then
            return -2
        fi
        depsyncflag=false
    fi

     cd $builddir

    common_args='target_os="linux" skia_use_egl=true skia_gl_standard="gles" skia_use_gl=true skia_enable_vulkan_debug_layers=false skia_use_x11=false skia_use_fontconfig=false skia_use_dng_sdk=false skia_enable_tools=false is_official_build=true is_debug=false is_component_build=false skia_use_system_freetype2=false skia_use_system_libwebp=false skia_use_system_libpng=false skia_use_system_libjpeg_turbo=false skia_use_system_harfbuzz=false skia_use_system_expat=false skia_use_system_zlib=false skia_use_system_icu=false'

    case "$ARCH" in
        armeabi-v7a)
            target_cpu="arm"
            extra_cflags=' extra_cflags=["-mfloat-abi=softfp"]'
            ;;
        arm64-v8a)
            target_cpu="arm64"
            extra_cflags=""
            ;;
        x86_64)
            target_cpu="x64"
            extra_cflags=""
            ;;
        *)
            echo "Unsupported ARCH: $ARCH" >&2
            return 1
            ;;
    esac
}

build() {
    gn_args="target_cpu=\"$target_cpu\" $common_args$extra_cflags"
    bin/gn gen $ARCH-build --ide=json --json-ide-script=../../gn/gn_to_cmake.py --args="$gn_args" > $PKGBUILD_ROOT/skia_$ARCH-build.log 2>&1
    cd $OLDPWD
    cd $builddir/$ARCH-build
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" -B./ -S./ >> $PKGBUILD_ROOT/skia_$ARCH-build.log 2>&1
    $MAKE VERBOSE=1 >> $PKGBUILD_ROOT/skia_$ARCH-build.log 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {

    # 库不支持make install，手动拷贝头文件和库文件
    installdir=$LYCIUM_ROOT/usr/$pkgname/$ARCH
    sourcedir=`pwd`/$builddir
    mkdir -p $installdir
    mkdir -p $installdir/lib
    mkdir -p $installdir/include
    cp $sourcedir/include/* $installdir/include -rfa
    cp $sourcedir/$ARCH-build/*.a $installdir/lib -rfa
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

# 清理环境
cleanbuild() {
    # 该库代码，下载后多达4G多，而且因为网络问题可能下载容易出问题
    rm -rf ${PWD}/$builddir/armeabi-v7a-build ${PWD}/$builddir/arm64-v8a-build ${PWD}/$builddir/x86_64-build
}
