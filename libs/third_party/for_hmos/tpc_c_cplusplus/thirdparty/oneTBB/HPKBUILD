pkgname=oneTBB
pkgver=v2022.3.0
pkgrel=0
pkgdesc="oneAPI Threading Building Blocks (oneTBB)"
url="https://uxlfoundation.github.io/oneTBB/"
archs=("x86_64" "armeabi-v7a" "arm64-v8a")
license=(" Apache License Version 2.0")
depends=()
makedepends=()

source="https://github.com/uxlfoundation/$pkgname/archive/refs/tags/$pkgver.tar.gz"

autounpack=true
downloadpackage=true

builddir=$pkgname-${pkgver:1}
packagename=$builddir.tar.gz
patchflag=true

prepare() {
    if $patchflag
    then
        cd $builddir
        #适配鸿蒙系统加入编译宏OHOS_PLATFORM
        patch -p1 < $PKGBUILD_ROOT/oneTBB_2022.3.0_oh_pkg.patch > $publicbuildlog 2>&1
        # patch只需要打一次,关闭打patch
        patchflag=false
        cd $OLDPWD
    fi
    mkdir -p $builddir/$ARCH-build
}

build() {
    cd $builddir
    # 关闭编译严格检查
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" -DOHOS_PLATFORM=ON -DTBB_STRICT=OFF -DTBB_TEST=ON \
      -DCMAKE_CXX_FLAGS="-fno-emulated-tls" \
      -B$ARCH-build -S./ > $buildlog 2>&1
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    $MAKE -C $ARCH-build install >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

# 清理环境
cleanbuild() {
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
    return 0
}
