pkgname=libsamplerate
pkgver=0.2.2
pkgrel=0
pkgdesc="An audio Sample Rate Conversion library"
url="https://github.com/libsndfile/libsamplerate/"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("BSD License")
depends=("libsndfile")
source="https://github.com/libsndfile/libsamplerate/archive/refs/tags/0.2.2.tar.gz"
autounpack=true
downloadpackage=true
buildtools="cmake"
builddir=$pkgname-$pkgver
packagename=$builddir.tar.gz

prepare() {
    mkdir -p $builddir/$ARCH-build
}

build() {
    cd $builddir
    
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
    -DOHOS_ARCH=$ARCH \
    -B$ARCH-build -S./ -L \
    -DLIBSAMPLERATE_EXAMPLES=OFF >> `pwd`/$ARCH-build/make.log 2>&1
    
    make -j4 -C $ARCH-build >> `pwd`/$ARCH-build/build.log 2>&1
    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd "$builddir"
    make -C $ARCH-build install >> `pwd`/$ARCH-build/install.log 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}