source HPKBUILD > /dev/null 2>&1
logfile=${LYCIUM_THIRDPARTY_ROOT}/${pkgname}/${pkgname}_${ARCH}_${OHOS_SDK_VER}_test.log
openharmonycheck() {
    res=0
    cd $builddir/$ARCH-build/
	export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:${LYCIUM_ROOT}/usr/libprofiler/${ARCH}/lib
	export TERMINFO=${LYCIUM_ROOT}/usr/ncurses/${ARCH}/share/terminfo
	export TERM=xterm-256color
    ./test/profilerTest
    res=$?
    if [ $res -ne 0 ]
    then
        mkdir ${LYCIUM_FAULT_PATH}/${pkgname}
        cp Testing/Temporary/LastTest.log ${LYCIUM_FAULT_PATH}/${pkgname}/
    fi
    cd $OLDPWD
    return $res
}
