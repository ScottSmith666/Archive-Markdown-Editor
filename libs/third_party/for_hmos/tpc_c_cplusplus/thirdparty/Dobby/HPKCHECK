source HPKBUILD > /dev/null 2>&1
logfile=${LYCIUM_THIRDPARTY_ROOT}/${pkgname}/${pkgname}_${ARCH}_${OHOS_SDK_VER}_test.log

checkprepare() {
    return 0
}

openharmonycheck() {
    
    export LD_LIBRARY_PATH="$LYCIUM_ROOT/usr/unicorn/arm64-v8a/lib:$LYCIUM_ROOT/usr/capstone/arm64-v8a/lib64:$LD_LIBRARY_PATH"
    cd ${builddir}/${ARCH}-build/tests
    if [ $ARCH == "arm64-v8a" ];then
        ./test_insn_relo_arm64 > ${logfile} 2>&1 || return -1
    elif [ $ARCH == "armeabi-v7a" ];then
        ./test_insn_relo_arm > ${logfile} 2>&1 || return -1
   	elif [ $ARCH == "x86_64" ];then
        ./test_insn_relo_x64 > ${logfile} 2>&1 || return -1	    
    else
        echo "${ARCH} not support"
        return -1
    fi
    cd ${OLDPWD}
    return 0
}
