pkgname=Dobby
pkgver=e9fe7fbecae47a2287e761080f8b1133cc22e8fa
pkgrel=0
pkgdesc="Dobby a lightweight, multi-platform, multi-architecture exploit hook framework."
url="https://github.com/jmpews/Dobby"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=(Apache License)
depends=("capstone" "unicorn")
makedepends=()
source="https://github.com/jmpews/Dobby.git"

downloadpackage=false
autounpack=false
buildtools=cmake
clonesrcflag=true

builddir=${pkgname}-${pkgver}
packagename=$builddir.tar.gz

prepare() {
    if ${clonesrcflag}
    then
        git clone ${source} ${builddir} || return -1
        cd ${builddir}
        git reset --hard ${pkgver} || return -1
        patch -p1 < ../${pkgname}.patch || return -1
        cd ${OLDPWD}
        clonesrcflag=false
    fi
    mkdir -p ${builddir}/${ARCH}-build
    return 0
}

build() {
    cd ${builddir}
    PKG_CONFIG_LIBDIR="${pkgconfigpath}" ${OHOS_SDK}/native/build-tools/cmake/bin/cmake \
    -DDOBBY_DEBUG=ON \
    -DDOBBY_BUILD_EXAMPLE=ON \
    -DDOBBY_BUILD_TEST=ON \
    -DCMAKE_C_FLAGS="-s" \
    -DCMAKE_CXX_FLAGS="-s" \
    "$@" -B$ARCH-build -S./ -L
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd ${OLDPWD}
    return $ret
}

package() {
    if [ -d "${builddir}/${ARCH}-build" ]; then
        cd "${builddir}/${ARCH}-build"
    fi
     
    mkdir -p ${LYCIUM_ROOT}/usr/${pkgname}/${ARCH}/lib/
    cp -r libdobby* $LYCIUM_ROOT/usr/$pkgname/$ARCH/lib/
    
    mkdir -p $LYCIUM_ROOT/usr/$pkgname/$ARCH/include/    
    cp -r ../include/* $LYCIUM_ROOT/usr/$pkgname/$ARCH/include/

    cd ${OLDPWD}
    return 0
}

check() {
    echo "The test must be on an OpenHarmony device!"
    return 0 
}

cleanbuild() {
    rm -rf ${PWD}/${builddir}
    return 0 
}