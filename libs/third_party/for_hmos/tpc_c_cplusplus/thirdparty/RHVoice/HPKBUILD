pkgname=RHVoice
pkgver=1.8.0
pkgrel=0
pkgdesc="A free and open source speech synthesizer"
url="https://github.com/RHVoice/RHVoice"
archs=("x86_64" "armeabi-v7a" "arm64-v8a" )

license=("GPL-3.0")
depends=("portaudio")
makedepends=("gcc" "pkg-config")
source="https://github.com/RHVoice/RHVoice/releases/download/1.8.0/rhvoice-1.8.0.tar.gz"

downloadpackage=true
autounpack=true
buildtools="cmake"

builddir="rhvoice-1.8.0"
packagename=$builddir.tar.gz

patchflag=true

prepare() {
    cd $builddir

    if [ $patchflag == true ]
    then
        local patch_file="rhvoice_1.8.0_oh_pkg.patch"
        patch -p1 < "../$patch_file"
        patchflag=false
    fi
    cd ${OLDPWD}
}

build() {
    cd $builddir
    PORTAUDIO_BASE="${LYCIUM_ROOT}/usr/portaudio"
    PORTAUDIO_LIB_DIR="${PORTAUDIO_BASE}/${ARCH}/lib"
    PORTAUDIO_INCLUDE_DIR="${PORTAUDIO_BASE}/${ARCH}/include"
    
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DOHOS_ARCH=$ARCH \
        -DPORTAUDIO_LIB_DIR=${PORTAUDIO_LIB_DIR} \
        -DPORTAUDIO_INCLUDE_DIR=${PORTAUDIO_INCLUDE_DIR} \
        -B$ARCH-build -S./ -L \
        -DWITH_PORTAUDIO=ON \
        -DWITH_LIBAO=OFF \
        -DWITH_PULSE=OFF \

    $MAKE -C $ARCH-build  >> $buildlog 2>&1

    ret=$?
    cd $OLDPWD
    return $ret
}

package() {
    cd $builddir
    $MAKE -C $ARCH-build install >> $buildlog 2>&1
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}