pkgname=libproxy
pkgver=0.4.18
pkgrel=0
pkgdesc="A library that provides automatic proxy configuration management"
url="https://github.com/libproxy/libproxy"
archs=("armeabi-v7a" "arm64-v8a" "x86_64")
license=("LGPL")
depends=()
makedepends=("autoconf" "automake" "libtool")
source="https://github.com/libproxy/libproxy/archive/refs/tags/0.4.18.tar.gz"

downloadpackage=true
autounpack=true
buildtools=cmake

builddir=libproxy-0.4.18
packagename=$builddir.tar.gz
clonesrcflag=true

prepare() {
    if ${clonesrcflag}
    then
        cd $builddir
        patch -p1 < ../libproxy.patch
        clonesrcflag=false
    fi
}

build() {
    cd $builddir

    # 禁用 GNOME3 和 Python 绑定，避免交叉编译时依赖主机系统库，
    # 只保留 OpenHarmony 所需的核心 C/C++ 库功能，减少构建干扰。
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DOHOS_ARCH=$ARCH \
        -B$ARCH-build \
        -S./ \
        -DWITH_GNOME3=OFF \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTING=ON \
        -DBUILD_EXAMPLES=ON \
        -DWITH_GNOME3=OFF \
        -DWITH_PYTHON2=OFF \
        -DWITH_PYTHON3=OFF \
        -DCMAKE_C_FLAGS="-s" \
        -DCMAKE_CXX_FLAGS="-s" \
        -L
    make -j4 -C $ARCH-build
    make -j4 -C $ARCH-build help 2>/dev/null | grep -i test || echo "没有找到测试目标"
    make -j4 -C $ARCH-build test 2>/dev/null; 
    cd $OLDPWD
    return $?
}

package() {
    cd $builddir
    DESTDIR="$pkgdir" make -C $ARCH-build install
    cd $OLDPWD
}

check() {
    echo "The test must be on an OpenHarmony device!"
}

cleanbuild() {
    rm -rf ${PWD}/$builddir
}