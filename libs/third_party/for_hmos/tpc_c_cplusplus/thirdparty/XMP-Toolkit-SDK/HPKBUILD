pkgname=XMP-Toolkit-SDK
pkgver=v2025.03
pkgrel=0
pkgdesc="The XMP Toolkit allows you to integrate XMP functionality into your product or solution"
url="https://github.com/adobe/XMP-Toolkit-SDK"
archs=("arm64-v8a" "armeabi-v7a" "x86_64")
license=("BSD-3")
depends=()
makedepends=()

source="https://github.com/adobe/$pkgname/archive/refs/tags/$pkgver.tar.gz"

autounpack=true
downloadpackage=true

builddir=$pkgname-${pkgver:1}
packagename=$builddir.tar.gz

downloadThridparty=true
patchflag=true

prepare() {
    if $patchflag
    then
        cd $builddir
        # 该patch添加OHOS平台识别、编译参数复用、重定义OHOS编译产物的路径、修改测试用例错误路径
        patch -p1 < $PKGBUILD_ROOT/XMP-Toolkit-SDK_v2025.03_oh_pkg.patch > $publicbuildlog 2>&1
        patchflag=false
        cd $OLDPWD
    fi
    mkdir -p $builddir/$ARCH-build
    if $downloadThridparty
    then
        # download expat
        download https://master.dl.sourceforge.net/project/expat/expat/2.5.0/expat-2.5.0-RENAMED-VULNERABLE-PLEASE-USE-2.6.2-INSTEAD.tar.xz $builddir/third-party/expat/expat-2.5.0.tar.xz
        cd $builddir/third-party/expat/
        unpack expat-2.5.0.tar.xz
        cp -rf expat-2.5.0/lib ./
        rm -rf expat-2.5.0.tar.xz
        rm -rf expat-2.5.0
        cd $OLDPWD
        # download zlib
        cd $builddir/third-party/zlib
        git clone https://github.com/madler/zlib.git -b v1.3.1.2 zlib-1.3.1.2
        cp -rf zlib-1.3.1.2/* ./
        rm -rf zlib-1.3.1.2
        cd $OLDPWD
        downloadThridparty=false
    fi
    mkdir -p $builddir/XMPCore/resource/ohos/
    cp -r $builddir/XMPCore/resource/android/* $builddir/XMPCore/resource/ohos/
    mkdir -p $builddir/XMPFiles/resource/ohos/
    cp -r $builddir/XMPFiles/resource/android/* $builddir/XMPFiles/resource/ohos/
}

build() {
    local dir=`pwd`
    cd $builddir
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DCMAKE_CXX_FLAGS="-fexceptions" \
        -DXMP_BUILD_STATIC="Off" \
        -B$ARCH-build -S./build > $buildlog 2>&1
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?

    cd samples
    ${OHOS_SDK}/native/build-tools/cmake/bin/cmake "$@" \
        -DCMAKE_CXX_FLAGS="-fexceptions" \
        -DXMP_BUILD_STATIC="Off" \
        -B$ARCH-build -S./build/cmake >> $buildlog 2>&1
    cd $dir
    return $ret
}

package() {
    cd $builddir
    mkdir -p $LYCIUM_ROOT/usr/$pkgname/$ARCH/lib/
    cp -r public/include/ $LYCIUM_ROOT/usr/$pkgname/
    cp -f public/libraries/$ARCH-build/release/*.so $LYCIUM_ROOT/usr/$pkgname/$ARCH/lib/
    cd $OLDPWD
}

check() {
    cd $builddir/samples
    $MAKE VERBOSE=1 -C $ARCH-build >> $buildlog 2>&1
    ret=$?
    cd $OLDPWD
}

cleanbuild() {
    rm -rf ${PWD}/$builddir #${PWD}/$packagename
}
