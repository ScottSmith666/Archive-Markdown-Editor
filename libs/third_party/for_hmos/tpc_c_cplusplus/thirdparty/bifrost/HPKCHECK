source HPKBUILD > /dev/null 2>&1

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
logfile=${SCRIPT_DIR}/${pkgname}_${ARCH}_${OHOS_SDK_VER}_test.log

openharmonycheck() {
    
    cd "$SCRIPT_DIR/bifrost-1.3.5-${ARCH}-build/${ARCH}-build/src"

    chmod +x Bifrost

    cat > test_reads.fasta << 'EOF'
>read1
ATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCG
>read2
GCTAGCTAGCTAGCTAGCTAGCTAGCTAGCTAGCTAGCTAGCTAGCTAGCTA
>read3
AAAACCCCGGGGTTTTAAAACCCCGGGGTTTTAAAACCCCGGGGTTTTAAAA
EOF
    
    if [ ! -f "test_reads.fasta" ]; then
        echo "错误: 测试序列文件创建失败" >> "$logfile"
        return 1
    fi

    ./Bifrost build -t 4 -k 21 -r test_reads.fasta -o test_graph_new -v >> "$logfile" 2>&1
    
    if [ ! -f "test_graph_new.gfa.gz" ] || [ ! -f "test_graph_new.bfi" ]; then
        echo "错误: 图构建失败" >> "$logfile"
        return 1
    fi

    cat > queries.fasta << 'EOF'
>query1
ATCGATCGATCGATCGATCGATCG
>query2
GCTAGCTAGCTAGCTAGCTAGCTA
EOF
    
    if [ ! -f "queries.fasta" ]; then
        echo "错误: 查询文件创建失败" >> "$logfile"
        return 1
    fi

    mkdir -p output
    ./Bifrost query -g test_graph_new.gfa.gz -I test_graph_new.bfi -q queries.fasta -o output/results -v >> "$logfile" 2>&1

    if [ ! -f "output/results.tsv" ]; then
        echo "错误: 结果文件不存在" >> "$logfile"
        return 1
    fi
    
    LINE_COUNT=$(wc -l < output/results.tsv)
    if [ "$LINE_COUNT" -lt 2 ]; then
        echo "错误: 结果文件格式异常" >> "$logfile"
        return 1
    fi
    
    return 0
}
